# Optional: bring your own pocket key. If unset, hoodpocket generates a fresh
# wallet at ~/.hoodpocket/wallet.json on first run. Never reuse a savings key.
#   cast wallet new        (Foundry)  — or any wallet app's "create account"
HOODPOCKET_PRIVATE_KEY=

# Optional: path to the config file (default: ./hoodpocket.config.json)
# HOODPOCKET_CONFIG=hoodpocket.config.json
